  Address verification service definitions.
  Import via Business Manager > Administration > Operations > Import & Export.
-->
<services xmlns="http://www.demandware.com/xml/impex/services/2014-09-26">

    <!-- Credentials: third-party API credentials (Loqate, Experian, etc.) -->
    <service-credential service-credential-id="addressverification.credentials">
        <url>https://api.addressy.com</url>
        <!-- Merchant replaces with their provider's API endpoint -->
    </service-credential>

    <!-- Profile: timeout settings for address lookups -->
    <service-profile service-profile-id="addressverification.profile">
        <timeout-millis>3000</timeout-millis>
        <rate-limit-enabled>false</rate-limit-enabled>
    </service-profile>

    <!-- Service: autocomplete suggestions -->
    <service service-id="addressverification.suggest" service-type="HTTP">
        <display-name>Address Verification — Autocomplete</display-name>
        <service-credential>addressverification.credentials</service-credential>
        <service-profile>addressverification.profile</service-profile>
    </service>

    <!-- Service: full address verification -->
    <service service-id="addressverification.verify" service-type="HTTP">
        <display-name>Address Verification — Verify</display-name>
        <service-credential>addressverification.credentials</service-credential>
        <service-profile>addressverification.profile</service-profile>
    </service>

</services>
